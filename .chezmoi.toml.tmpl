{{- $machine := promptStringOnce . "machine" "Machine type (personal/work)" "personal" -}}

sourceDir = {{ .chezmoi.sourceDir | quote }}

[data]
machine = {{ $machine | quote }}

{{- if eq $machine "work" }}

[data.work]
email = {{ promptStringOnce . "work.email" "Work email address" | quote }}
teamName = {{ promptStringOnce . "work.teamName" "Team name" | quote }}
teamId = {{ promptStringOnce . "work.teamId" "Team ID" | quote }}
gitlabNamespace = {{ promptStringOnce . "work.gitlabNamespace" "GitLab namespace" | quote }}
sourcegraphSite = {{ promptStringOnce . "work.sourcegraphSite" "Sourcegraph site" | quote }}
atlassianSite = {{ promptStringOnce . "work.atlassianSite" "Atlassian site" | quote }}
atlassianApiToken = {{ promptStringOnce . "work.atlassianApiToken" "Atlassian API token" | quote }}
gleanServerUrl = {{ promptStringOnce . "work.gleanServerUrl" "Glean server URL" | quote }}
gleanClientId = {{ promptStringOnce . "work.gleanClientId" "Glean OAuth client ID" | quote }}

{{- end }}
