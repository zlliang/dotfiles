{
  {{- if eq .machine "work" }}
  "mcpServers": {
    "booking-genai-toolbox": {
      "type": "stdio",
      "command": "bk",
      "args": ["genai:mcp:toolbox"],
      "env": {
        "MCP_TIMEOUT": "30000"
      }
    },
    "exa": {
      "url": "https://mcp.exa.ai/mcp"
    }
  },
  {{- else }}
  "mcpServers": {
    "exa": {
      "url": "https://mcp.exa.ai/mcp"
    }
  },
  {{- end }}
  "imports": []
}
