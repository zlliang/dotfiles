#!/usr/bin/env python3

import shutil
import subprocess
from pathlib import Path


def run(cmd: list[str]) -> None:
    print(f"$ {' '.join(cmd)}")
    subprocess.run(cmd, check=True)


def reset_agents_directories(dirs: list[Path]) -> None:
    for d in dirs:
        print(f"Removing {d}")
        shutil.rmtree(d, ignore_errors=True)


def install_skills(repo: str, skills: list[str] | None = None) -> None:
    agents = ["amp"]  # Only installs to `~/.agents/skills`
    run(["npx", "-y", "skills", "add", repo, *(["--skill", *skills] if skills else []), "--full-depth", "-g", "-y", "-a", *agents])


def install_brew(packages: list[str]) -> None:
    installed = subprocess.run(["brew", "leaves"], capture_output=True, text=True).stdout.splitlines()
    missing = [p for p in packages if p not in installed]
    if missing:
        run(["brew", "install", *missing])


def bun_package_name(line: str) -> str | None:
    name = line.strip().removeprefix("├── ").removeprefix("└── ").split(" ", 1)[0]
    if not name or name.startswith("/"):
        return None
    if name.startswith("@"):
        return name.rsplit("@", 1)[0]
    return name.split("@", 1)[0]


def install_bun(packages: list[str]) -> None:
    installed = subprocess.run(["bun", "list", "-g"], capture_output=True, text=True).stdout.splitlines()
    installed_names = {name for line in installed if (name := bun_package_name(line))}
    missing = [p for p in packages if p not in installed_names]
    if missing:
        run(["bun", "add", "-g", "--ignore-scripts", *missing])


reset_agents_directories([
    Path.home() / ".agents",
    Path.home() / ".pi" / "agent" / "skills",
])

install_skills("zlliang/skills")
install_brew(["gh"])
install_bun(["mcporter"])

install_skills("vercel-labs/agent-browser", ["agent-browser"])
install_bun(["agent-browser"])

{{- if eq .machine "work" }}

install_skills("https://gitlab.com/{{ .work.gitlabNamespace }}/personal/zilong.liang/skills")
install_brew([
    "atlassian/acli/acli",
    "sourcegraph/src-cli/src-cli",
])

install_skills("https://gitlab.com/gitlab-org/ai/skills", [
    "glab",
    "glab-glql",
])
install_brew(["glab"])

install_skills("https://github.com/gleanwork/glean-cli", ["glean-cli"])
install_brew(["gleanwork/tap/glean-cli"])

install_skills("googleworkspace/cli", [
    "gws-shared",
    "gws-gmail",
    "gws-calendar",
    "gws-drive",
    "gws-docs",
    "gws-sheets",
    "gws-slides",
])
install_brew(["googleworkspace-cli"])

shared_repo = "https://gitlab.com/{{ .work.gitlabNamespace }}/genai-eng/coding-agent-tools/-/tree/main"
install_skills(f"{shared_repo}/common/skills/bpages")

{{- end }}
