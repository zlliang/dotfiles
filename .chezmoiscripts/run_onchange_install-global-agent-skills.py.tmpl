#!/usr/bin/env python3

import shutil
import subprocess
from pathlib import Path


def run(cmd: list[str]) -> None:
    print(f"$ {' '.join(cmd)}")
    subprocess.run(cmd, check=True)


def resetAgentsDirectories(dirs: list[Path]) -> None:
    for d in dirs:
        print(f"Removing {d}")
        shutil.rmtree(d, ignore_errors=True)


def installSkills(repo: str, skills: list[str] | None = None) -> None:
    agents = ["codex"]  # Only `~/.agents/skills`
    run(["npx", "-y", "skills", "add", repo, *(["--skill", *skills] if skills else []), "-g", "-y", "-a", *agents])


def installBrew(packages: list[str]) -> None:
    installed = subprocess.run(["brew", "list", "--formula", "-1"],capture_output=True, text=True).stdout.splitlines()
    missing = [p for p in packages if p not in installed]
    if missing:
        run(["brew", "install", *missing])


def bunPackageName(line: str) -> str | None:
    name = line.strip().removeprefix("├── ").removeprefix("└── ").split(" ", 1)[0]
    if not name or name.startswith("/"):
        return None
    if name.startswith("@"):
        return name.rsplit("@", 1)[0]
    return name.split("@", 1)[0]


def installBun(packages: list[str]) -> None:
    installed = subprocess.run(["bun", "list", "-g"], capture_output=True, text=True).stdout.splitlines()
    installedNames = {name for line in installed if (name := bunPackageName(line))}
    missing = [p for p in packages if p not in installedNames]
    if missing:
        run(["bun", "add", "-g", "--ignore-scripts", *missing])


resetAgentsDirectories([
    Path.home() / ".agents",
    Path.home() / ".pi" / "agent" / "skills",
])

installSkills("zlliang/skills", [
    "ast-grep",
    "gh-cli",
    "git-commit",
    "mcporter",
    "writing-issues-and-prs",
])
installBrew(["ast-grep", "gh"])
installBun(["mcporter"])

installSkills("vercel-labs/agent-browser", ["agent-browser"])
installBun(["agent-browser"])

{{- if eq .machine "work" }}
installSkills("git@gitlab.com:{{ .gitlabNamespace }}/skills", [
    "k8s-at-booking-com",
    "sourcegraph-cli",
    "working-at-booking-com",
    "writing-work-messages",
])
installBrew(["sourcegraph/src-cli/src-cli"])

installSkills("https://gitlab.com/gitlab-org/ai/skills", [
    "glab",
    "glab-glql",
])
installBrew(["glab"])

installSkills("googleworkspace/cli", [
    "gws-shared",
    "gws-gmail",
    "gws-calendar",
    "gws-drive",
    "gws-docs",
    "gws-sheets",
    "gws-slides",
])
installBrew(["googleworkspace-cli"])
{{- end }}
