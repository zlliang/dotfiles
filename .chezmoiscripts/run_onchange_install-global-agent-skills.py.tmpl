#!/usr/bin/env python3

import json
import shutil
import subprocess
from pathlib import Path


def run(cmd: list[str]) -> None:
    print(f"$ {' '.join(cmd)}")
    subprocess.run(cmd, check=True)


def resetAgentsDirectory() -> None:
    agentsDir = Path.home() / ".agents"
    print(f"Removing {agentsDir}")
    shutil.rmtree(agentsDir, ignore_errors=True)


def installSkills(repo: str, skills: list[str] | None = None) -> None:
    agents = ["codex"]  # Only `~/.agents/skills`
    run(["npx", "-y", "skills", "add", repo, *(["--skill", *skills] if skills else []), "-g", "-y", "-a", *agents])


def installBrew(packages: list[str]) -> None:
    installed = subprocess.run(["brew", "list", "--formula", "-1"],capture_output=True, text=True).stdout.splitlines()
    missing = [p for p in packages if p not in installed]
    if missing:
        run(["brew", "install", *missing])


def installPnpm(packages: list[str]) -> None:
    output = subprocess.run(["pnpm", "list", "-g", "--json"], capture_output=True, text=True).stdout
    installed: set[str] = set()
    for entry in json.loads(output or "[]"):
        installed.update(entry.get("dependencies", {}).keys())
    missing = [p for p in packages if p not in installed]
    if missing:
        run(["pnpm", "add", "-g", "--ignore-scripts", *missing])


resetAgentsDirectory()

installSkills("zlliang/skills")
installBrew(["gh"])

installSkills("vercel-labs/agent-browser", ["agent-browser"])
installPnpm(["agent-browser"])
run(["agent-browser", "install"])

installSkills("steipete/clawdis", ["mcporter"])
installPnpm(["mcporter"])

{{- if eq .machine "work" }}
installSkills("git@gitlab.com:{{ .gitlabNamespace }}/skills")

installSkills("googleworkspace/cli", [
    "gws-shared",
    "gws-calendar",
    "gws-drive",
    "gws-docs",
    "gws-gmail",
    "gws-sheets",
])
{{- end }}
