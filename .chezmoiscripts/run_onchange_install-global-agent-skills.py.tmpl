#!/usr/bin/env -S uv run --quiet --script
"""chezmoi script for installing global agent skills."""
# /// script
# ///

import subprocess


def run(cmd: list[str]) -> None:
    print(f"$ {' '.join(cmd)}")
    subprocess.run(cmd, check=True)


def installSkills(repo: str, skills: list[str] | None = None) -> None:
    agents = ["amp", "codex", "claude-code"]
    run(["npx", "skills", "add", repo, *(["--skill", *skills] if skills else []), "-g", "-y", "-a", *agents])


def installBrew(packages: list[str]) -> None:
    installed = subprocess.run(["brew", "list", "--formula", "-1"],capture_output=True, text=True).stdout.splitlines()
    missing = [p for p in packages if p not in installed]
    if missing:
        run(["brew", "install", *missing])


def installPnpm(packages: list[str]) -> None:
    installed = subprocess.run(["pnpm", "list", "-g", "--depth=0", "--parseable"], capture_output=True, text=True).stdout.splitlines()
    installedNames = {line.rsplit("/", 1)[-1] for line in installed if line}
    missing = [p for p in packages if p not in installedNames]
    if missing:
        run(["pnpm", "add", "-g", *missing, "--dangerously-allow-all-builds"])


installSkills("zlliang/skills", ["git-commit"])

installSkills("github/awesome-copilot", ["gh-cli"])
installBrew(["gh"])

installSkills("vercel-labs/agent-browser", ["agent-browser"])
installPnpm(["agent-browser"])
run(["agent-browser", "install"])

{{ if eq .machine "work" -}}
installSkills("googleworkspace/cli", [
    "gws-shared", "gws-admin-reports",
    "gws-calendar", "gws-calendar-agenda", "gws-calendar-insert",
    "gws-drive", "gws-drive-upload",
    "gws-docs", "gws-docs-write",
    "gws-gmail", "gws-gmail-forward", "gws-gmail-read", "gws-gmail-reply", "gws-gmail-reply-all", "gws-gmail-send", "gws-gmail-triage", "gws-gmail-watch",
    "gws-sheets", "gws-sheets-append", "gws-sheets-read",
    "gws-slides",
    "gws-forms",
])
{{ end -}}
