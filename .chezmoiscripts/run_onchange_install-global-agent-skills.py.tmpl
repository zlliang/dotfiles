#!/usr/bin/env -S uv run --quiet --script
"""chezmoi script for installing global agent skills."""
# /// script
# ///

import subprocess


def run(cmd: list[str]) -> None:
    print(f"$ {' '.join(cmd)}")
    subprocess.run(cmd, check=True)


def installSkills(repo: str, skills: list[str]) -> None:
    agents = ["amp", "codex", "claude-code"]
    run(["npx", "skills", "add", repo, "--skill", *skills, "-g", "-y", "-a", *agents])


def installBrew(packages: list[str]) -> None:
    run(["brew", "install", *packages])


def installPnpm(packages: list[str]) -> None:
    run(["pnpm", "add", "-g", *packages, "--dangerously-allow-all-builds"])


installSkills("github/awesome-copilot", ["gh-cli", "git-commit"])
installBrew(["gh"])

installSkills("vercel-labs/agent-browser", ["agent-browser"])
installPnpm(["agent-browser"])

{{ if eq .machine "work" -}}
installSkills("googleworkspace/cli", [
    "gws-shared", "gws-admin-reports",
    "gws-calendar", "gws-calendar-agenda", "gws-calendar-insert",
    "gws-drive", "gws-drive-upload",
    "gws-docs", "gws-docs-write",
    "gws-gmail", "gws-gmail-forward", "gws-gmail-read", "gws-gmail-reply", "gws-gmail-reply-all", "gws-gmail-send", "gws-gmail-triage", "gws-gmail-watch",
    "gws-sheets", "gws-sheets-append", "gws-sheets-read",
    "gws-slides",
    "gws-forms",
])
installBrew(["googleworkspace-cli"])
{{ end -}}
