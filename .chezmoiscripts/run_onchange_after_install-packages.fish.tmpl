#!/usr/bin/env fish

set -l brew_path

if test (id -u) -eq 0
  set brew_path /home/linuxbrew/.linuxbrew/bin/brew
  fish_add_path -g /home/linuxbrew/.linuxbrew/bin "$HOME/.local/bin"
else
  source "$HOME/.config/fish/config.fish"
  set brew_path (command -s brew)
end

if not test -x "$brew_path"
  echo "Homebrew not found at $brew_path" >&2
  exit 1
end

function run_brew --inherit-variable brew_path
  if test (id -u) -eq 0
    command runuser -u linuxbrew -- env \
      HOME=/home/linuxbrew USER=linuxbrew LOGNAME=linuxbrew \
      /bin/bash -c 'cd "$HOME" && exec "$@"' bash "$brew_path" $argv
  else
    command "$brew_path" $argv
  end
end

function install_missing_brew_packages
  set -l installed_packages (run_brew list --versions --json | jq -r '.formulae[].name, .casks[].token')
  set -l missing_packages

  for package in $argv
    if not contains -- (path basename "$package") $installed_packages
      set -a missing_packages "$package"
    end
  end

  if test (count $missing_packages) -gt 0
    run_brew install $missing_packages
  end
end

set -l brew_packages \
  bat \
  chezmoi \
  eza \
  fd \
  fnm \
  gh \
  jq \
  ripgrep \
  uv \
  zoxide

{{- if eq .chezmoi.os "darwin" }}
set -a brew_packages \
  mole \
  ghostty \
  keka \
  orbstack \
  thaw
{{- end }}

install_missing_brew_packages $brew_packages
or exit

if not type -q bun
  curl -fsSL https://bun.com/install | bash
  or exit
  fish_add_path -g "$HOME/.bun/bin"
end

if not type -q rustup
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path
  or exit
end

if not type -q amp
  curl -fsSL https://ampcode.com/install.sh | bash
  or exit
end

if not type -q pi
  bun add -g --ignore-scripts @earendil-works/pi-coding-agent
  or exit
end

if not test -d "$HOME/.agents/skills"
  setup-global-agent-skills
end
