{
  "providers": {
    {{- if eq .machine "work" }}
    "booking-genai": {
      "baseUrl": "https://gen-ai.prod.booking.com/anthropic/claude_code/",
      "api": "anthropic-messages",
      "apiKey": "!bkt --ttl=1m -- (bk auth:issue-token || (bk auth:login --skip-okta-auth > /dev/null 2>&1 && bk auth:issue-token))",
      "models": [
        {
          "id": "ml-asset:static-model/claude-opus-4-7",
          "name": "Claude Opus 4.7",
          "reasoning": true,
          "input": ["text", "image"],
          "contextWindow": 1000000,
          "maxTokens": 128000,
          "cost": { "input": 5, "output": 25, "cacheRead": 0.5, "cacheWrite": 6.25 },
          "compat": { "forceAdaptiveThinking": true }
        },
        {
          "id": "ml-asset:static-model/claude-sonnet-4-6",
          "name": "Claude Sonnet 4.6",
          "reasoning": true,
          "input": ["text", "image"],
          "contextWindow": 1000000,
          "maxTokens": 64000,
          "cost": { "input": 3, "output": 15, "cacheRead": 0.3, "cacheWrite": 3.75 },
          "compat": { "forceAdaptiveThinking": true }
        },
        {
          "id": "ml-asset:static-model/claude-haiku-4-5",
          "name": "Claude Haiku 4.5",
          "reasoning": true,
          "input": ["text", "image"],
          "contextWindow": 200000,
          "maxTokens": 64000,
          "cost": { "input": 1, "output": 5, "cacheRead": 0.1, "cacheWrite": 1.25 }
        }
      ]
    }
    {{- end }}
  }
}
