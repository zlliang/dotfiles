#!/usr/bin/env python3

import json
import sys
from collections import OrderedDict

existing = json.loads(sys.stdin.read().strip() or "{}")
settings = OrderedDict()

# Version
if "lastChangelogVersion" in existing:
    settings["lastChangelogVersion"] = existing["lastChangelogVersion"]

# Theme
settings["theme"] = existing.get("theme") or "light"

# Packages
settings["packages"] = ["npm:pi-system-theme"]

# Model
for key in ["defaultProvider", "defaultModel", "defaultThinkingLevel"]:
    if key in existing:
        settings[key] = existing[key]

json.dump(settings, sys.stdout, indent=2, ensure_ascii=False)
sys.stdout.write("\n")
