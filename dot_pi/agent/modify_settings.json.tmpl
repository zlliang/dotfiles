#!/usr/bin/env python3

import json
import sys
from collections import OrderedDict

existing = json.loads(sys.stdin.read().strip() or "{}")
settings = OrderedDict()

# Version
if "lastChangelogVersion" in existing:
    settings["lastChangelogVersion"] = existing["lastChangelogVersion"]

# Theme
settings["theme"] = existing.get("theme") or "light"

# Packages
settings["packages"] = [
    {{- if eq .machine "work" }}
    "ssh://git@gitlab.com/{{ .gitlabNamespace }}/pi-booking-genai",
    {{- end }}
    "npm:pi-system-theme",
    "git:github.com/zlliang/pi-spark",
]

# Markdown
settings["markdown"] = {"codeBlockIndent": ""}

# Project trust
settings["defaultProjectTrust"] = "always"

# Model
for key in ["defaultProvider", "defaultModel", "defaultThinkingLevel"]:
    if key in existing:
        settings[key] = existing[key]

# Custom
settings["booking-genai"] = {"showCost": "week"}

json.dump(settings, sys.stdout, indent=2, ensure_ascii=False)
sys.stdout.write("\n")
