{{- $anthropicProvider := ternary "booking-genai" "vercel-ai-gateway" (eq .machine "work") -}}
{{- $smallModelProvider := ternary "openai-codex" "deepseek" (eq .machine "work") -}}
{{- $smallModel := ternary "gpt-5.6-luna" "deepseek-v4-flash" (eq .machine "work") -}}

{
  "presets": {
    "gpt-sol": {
      "provider": "openai-codex",
      "model": "gpt-5.6-sol",
      "thinkingLevel": "high"
    },
    "gpt-terra": {
      "provider": "openai-codex",
      "model": "gpt-5.6-terra",
      "thinkingLevel": "high"
    },
    "claude-opus": {
      "provider": {{ $anthropicProvider | quote }},
      "model": "claude-opus-4-8",
      "thinkingLevel": "high"
    },
    "claude-sonnet": {
      "provider": {{ $anthropicProvider | quote }},
      "model": "claude-sonnet-5",
      "thinkingLevel": "high"
    {{- if eq .machine "work" }}
    }
    {{- else }}
    },
    "glm": {
      "provider": "fireworks",
      "model": "accounts/fireworks/models/glm-5p2",
      "thinkingLevel": "xhigh"
    },
    "deepseek": {
      "provider": "deepseek",
      "model": "deepseek-v4-flash",
      "thinkingLevel": "xhigh"
    }
    {{- end }}
  },
  "recap": {
    "provider": {{ $smallModelProvider | quote }},
    "model": {{ $smallModel | quote }},
    "thinkingLevel": "off"
  },
  "title": {
    "provider": {{ $smallModelProvider | quote }},
    "model": {{ $smallModel | quote }},
    "thinkingLevel": "off"
  }
}
