#!/usr/bin/env python3

import json
import sys
from collections import OrderedDict

existing = json.loads(sys.stdin.read().strip() or "{}")
settings = OrderedDict()


claudeOpus = {
    "provider": {{ ternary "booking-genai" "vercel-ai-gateway" (eq .machine "work") | quote }},
    "model": {{ ternary "claude-opus-4-8" "anthropic/claude-opus-4.8" (eq .machine "work") | quote }},
    "thinkingLevel": "high",
}

claudeSonnet = {
    "provider": {{ ternary "booking-genai" "vercel-ai-gateway" (eq .machine "work") | quote }},
    "model": {{ ternary "claude-sonnet-5" "anthropic/claude-sonnet-5" (eq .machine "work") | quote }},
    "thinkingLevel": "high",
}

settings["presets"] = {
    "gpt-sol": {
        "provider": "openai-codex",
        "model": "gpt-5.6-sol",
        "thinkingLevel": "high",
    },
    "gpt-terra": {
        "provider": "openai-codex",
        "model": "gpt-5.6-terra",
        "thinkingLevel": "high",
    },
    "claude-opus": claudeOpus,
    "cluade-sonnet": claudeSonnet,
    {{- if ne .machine "work" }}
    "glm": {
      "provider": "fireworks",
      "model": "accounts/fireworks/routers/glm-5p2-fast",
      "thinkingLevel": "max",
    },
    "deepseek": {
      "provider": "deepseek",
      "model": "deepseek-v4-flash",
      "thinkingLevel": "max",
    },
    {{- end }}
}

smallModelSettings = {
    "provider": {{ ternary "openai-codex" "deepseek" (eq .machine "work") | quote }},
    "model": {{ ternary "gpt-5.6-luna" "deepseek-v4-flash" (eq .machine "work") | quote }},
    "thinkingLevel": "off",
}

settings["recap"] = smallModelSettings
settings["title"] = smallModelSettings

json.dump(settings, sys.stdout, indent=2, ensure_ascii=False)
sys.stdout.write("\n")
