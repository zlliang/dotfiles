#!/usr/bin/env -S uv run --quiet --script
"""chezmoi script for ~/.codex/config.toml

Merges managed fields into the existing file without clobbering
runtime state that Codex writes (projects, etc.).

Requires: tomlkit (invoked via uv run --with tomlkit)
"""
# /// script
# dependencies = ["tomlkit"]
# ///

import sys
import tomlkit

existing = sys.stdin.read().strip()
data = tomlkit.loads(existing) if existing else tomlkit.document()

# Sync shared configs
data["model"] = "gpt-5.5"
data["model_reasoning_effort"] = "high"

# Use tomlkit.table() instead of plain dict to render as [sections], not inline tables
features = data.setdefault("features", tomlkit.table())
features["memories"] = True
if "features" not in data:
    data["features"] = features

plugins = data.setdefault("plugins", tomlkit.table())
for name in ("computer-use@openai-bundled", "browser-use@openai-bundled"):
    plug = plugins.setdefault(name, tomlkit.table())
    plug["enabled"] = True
    if name not in plugins:
        plugins[name] = plug

# Sync work-specific MCP servers
{{- if eq .machine "work" }}
mcp = data.setdefault("mcp_servers", tomlkit.table())
tb = tomlkit.table()
tb["command"] = "bk"
tb["args"] = ["genai:mcp:toolbox", "--enable-preview"]
tb.add(tomlkit.nl())  # blank line before [*.env] subsection
env = tomlkit.table()
env["MCP_TIMEOUT"] = "30000"
tb["env"] = env
mcp["Toolbox-Preview"] = tb
mcp.add(tomlkit.nl())  # blank line before remaining sections (e.g. [projects.*])
{{- else }}
data.pop("mcp_servers", None)
{{- end }}

sys.stdout.write(tomlkit.dumps(data))
