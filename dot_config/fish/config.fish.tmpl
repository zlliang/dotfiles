# Environment variables and general settings
set -gx LANG "en_US.UTF-8"
set -gx SSH_KEY_PATH "$HOME/.ssh/rsa_id"
set -gx EDITOR {{ ternary "code --wait" "vim" (eq .chezmoi.os "darwin") | quote }}
fish_add_path -g "$HOME/.local/bin"

if status is-interactive
  stty -echoctl 2>/dev/null   # Disable `^C` display when pressing Ctrl+C

  # Set cursor style to `line` internally
  # 1 -> blinking block
  # 2 -> solid block
  # 3 -> blinking underscore
  # 4 -> solid underscore
  # 5 -> blinking vertical bar
  # 6 -> solid vertical bar
  echo -ne "\e[5 q"
  function postexec --on-event fish_postexec; echo -ne "\e[5 q"; end
end

{{- if eq .chezmoi.os "darwin" }}

# Homebrew
set -gx HOMEBREW_PREFIX "/opt/homebrew"
set -gx HOMEBREW_CELLAR "/opt/homebrew/Cellar"
set -gx HOMEBREW_REPOSITORY "/opt/homebrew"
set -gx HOMEBREW_BOTTLE_DOMAIN "https://mirrors.tuna.tsinghua.edu.cn/homebrew-bottles"
set -gx HOMEBREW_NO_ENV_HINTS 1
fish_add_path -g "/opt/homebrew/bin" "/opt/homebrew/sbin"

{{- end }}

# System utilities
if type -q eza
  alias ls "eza -lhH --no-quotes --group-directories-first --git --time-style=long-iso"
  alias la "ls -a"
  alias tree "ls --tree --level=2"
end
if type -q bat
  alias cat "bat"
  {{- if eq .chezmoi.os "darwin" }}
  if defaults read -g AppleInterfaceStyle >/dev/null 2>&1
    set -gx BAT_THEME "default"
  else
    set -gx BAT_THEME "GitHub"
  end
  {{- end }}
end
if type -q zoxide
    zoxide init fish | source
end

# JavaScript
# Use `nodenv` to manage Node.js versions. See https://github.com/nodenv/nodenv.
if type -q nodenv
  nodenv init - fish | source
end
{{- if eq .machine "work" }}
set -gx COREPACK_NPM_REGISTRY "https://mirrors.tencent.com/npm"
set -gx COREPACK_INTEGRITY_KEYS "0"
{{- end }}
set -gx NODE_OPTIONS "--no-warnings"
set -gx NODE_TLS_REJECT_UNAUTHORIZED 0
set -gx COREPACK_ENABLE_AUTO_PIN 0
set -gx PNPM_HOME "$HOME/.pnpm"
fish_add_path -g "$HOME/.bun/bin"

# Python
# Suppress default virtual env prompt
set -gx VIRTUAL_ENV_DISABLE_PROMPT "true"

{{- if eq .machine "work" }}

# Identity
set -gx USER_NAME "$USER"
set -gx WORK_EMAIL "{{ .work.email }}"
set -gx TEAM_NAME "{{ .work.teamName }}"
set -gx TEAM_ID "{{ .work.teamId }}"

# BK CLI
if type -q bk
  bk completion fish | source
  set -gx BK_AUTH_SSO_TIMEOUT 600000
end

# Sourcegraph CLI
set -gx SRC_ENDPOINT "https://sourcegraph.booking.com"

# Google Cloud SDK
if test -f $HOME/.local/share/google-cloud-sdk/path.fish.inc
  source $HOME/.local/share/google-cloud-sdk/path.fish.inc
end

{{- end }}
