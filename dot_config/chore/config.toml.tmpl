shell = ["bash", "-c"]

[[tasks]]
name = "update"
description = "Update all developer tools"
steps = [
  "update-dotfiles",
  "update-homebrew",
  "update-node",
  "update-bun",
  "update-python",
  "update-rust",
  "update-amp",
  "update-pi",
  "update-agent-skills",
  {{- if eq .machine "work" }}
  "update-bk",
  {{- end }}
]

[[tasks]]
name = "update-dotfiles"
description = "Update dotfiles"
check = "chezmoi"
run = ["chezmoi update --force"]

[[tasks]]
name = "update-homebrew"
description = "Update Homebrew packages"
check = "brew"
run = [
  "brew update",
  "brew upgrade -y",
  "brew cleanup",
]

[[tasks]]
name = "update-node"
description = "Update Node.js (LTS) via nodenv"
check = "nodenv"
run = ["""
set -e
node_index=$(curl -fsSL https://nodejs.org/dist/index.tab)
lts_versions=$(printf '%s\n' "$node_index" | awk 'NR > 1 && $10 != "-" {gsub(/^v/, "", $1); print $1}')
if [ -z "$lts_versions" ]; then
  echo "Failed to resolve LTS Node.js versions"
  exit 1
fi
available=$(nodenv install -l | sed 's/^[[:space:]]*//' | grep -E '^[0-9]+\\.[0-9]+\\.[0-9]+$')
latest_lts=""
for v in $lts_versions; do
  if printf '%s\n' "$available" | grep -qx "$v"; then
    latest_lts="$v"
    break
  fi
done
if [ -z "$latest_lts" ]; then
  echo "No installable LTS Node.js version found via nodenv"
  exit 1
fi
echo "Installing Node.js $latest_lts via nodenv..."
nodenv install -s "$latest_lts"
echo "Setting global Node.js version to $latest_lts..."
nodenv global "$latest_lts"
nodenv rehash
major="${latest_lts%%.*}"
for installed in $(nodenv versions --bare); do
  case "$installed" in
    "$latest_lts") ;;
    "$major".*)
      echo "Removing old Node.js $installed..."
      nodenv uninstall -f "$installed"
      ;;
  esac
done
echo "Enabling corepack..."
corepack enable
corepack prepare pnpm@latest --activate
"""]

[[tasks]]
name = "update-bun"
description = "Update Bun global packages"
check = "bun"
run = ["bun update -g --ignore-scripts --latest"]

[[tasks]]
name = "update-python"
description = "Update Python (with uv)"
check = "uv"
run = [
  "uv python install --default",
  "uv python upgrade",
  """
set -e
install_dir=$(uv python dir)
old_versions=$(uv python list --only-installed --output-format json \
  | jq -r --arg dir "$install_dir" '
      [.[] | select(.path | startswith($dir))]
      | unique_by(.key)
      | group_by([.version_parts.major, .version_parts.minor])
      | map(sort_by(.version_parts.patch) | .[0:-1])
      | flatten
      | .[].key
    ')
for v in $old_versions; do
  echo "Removing old Python $v..."
  uv python uninstall "$v"
done
""",
]

[[tasks]]
name = "update-rust"
description = "Update Rust"
check = "rustup"
run = [
  "rustup self update",
  "rustup update",
]

[[tasks]]
name = "update-amp"
description = "Update Amp"
check = "amp"
run = ["amp update"]

[[tasks]]
name = "update-pi"
description = "Update Pi and its packages"
check = "pi"
run = [
  "pi update --all",
  "cd ~/.pi/agent/extensions && npm update",
]

[[tasks]]
name = "update-agent-skills"
description = "Update global agent skills"
check = "setup-global-agent-skills"
run = ["setup-global-agent-skills"]

[[tasks]]
name = "pull-repos"
description = "Pull latest changes for all personal repos"
run = ["""
for dir in ~/workspace/github/zlliang/*/; do
  if [ -d "$dir/.git" ]; then
    echo "Pulling $(basename "$dir")..."
    git -C "$dir" pull --ff-only || true
  fi
done
"""]

{{- if eq .machine "work" }}

[[tasks]]
name = "update-bk"
description = "Update BK CLI and its plugins"
check = "bk"
run = ["bk update"]

[[tasks]]
name = "bklogin"
description = "Log in to Booking.com"
steps = ["bklogin-ssh", "bklogin-auth", "bklogin-glean-auth"]

[[tasks]]
name = "bklogin-ssh"
description = "SSH to Booking.com"
interactive = true
run = ["ssh -A ssh.booking.com"]

[[tasks]]
name = "bklogin-auth"
description = "Authenticate with bk CLI"
check = "bk"
run = ["bk auth:login --skip-okta-auth"]

[[tasks]]
name = "bklogin-glean-auth"
description = "Authenticate with Glean CLI"
check = "glean-auth-login"
run = ["glean-auth-login"]

{{- end }}
