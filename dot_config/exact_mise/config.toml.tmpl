[tools]
# Utilities
bat = "latest"
chezmoi = "latest"
eza = "0.23.4"
fd = "latest"
gh = "latest"
jq = "latest"
ripgrep = "latest"
usage = "latest"
zoxide = "latest"
# Languages
node = "lts"
bun = "latest"
python = "latest"
uv = "latest"
rust = "latest"
# AI tools
"github:earendil-works/pi" = "latest"
"npm:agent-browser" = "latest"
"npm:mcporter" = "latest"

[tasks.update]
description = "Update all developer tools"
run = [
  { task = "update:dotfiles" },
  {{- if eq .chezmoi.os "darwin" }}
  { task = "update:homebrew" },
  {{- end }}
  { task = "update:mise" },
  { task = "update:amp" },
  { task = "update:pi" },
  { task = "update:agent-skills" },
  {{- if eq .machine "work" }}
  { task = "update:bk" },
  {{- end }}
]

[tasks."update:dotfiles"]
description = "Update dotfiles"
run = "chezmoi update --force"

{{- if eq .chezmoi.os "darwin" }}

[tasks."update:homebrew"]
description = "Update Homebrew packages"
run = [
  "brew update",
  "brew upgrade -y",
  "brew cleanup",
]
{{- end }}

[tasks."update:mise"]
description = "Update mise and managed tools"
run = [
  "mise self-update -y",
  "mise upgrade",
  "mise prune",
]

[tasks."update:amp"]
description = "Update Amp"
run = "amp update"

[tasks."update:pi"]
description = "Update Pi packages"
run = [
  "pi update --extensions",
  { task = "update:pi-dependencies" },
]

[tasks."update:pi-dependencies"]
dir = "{{ .chezmoi.homeDir }}/.pi/agent/extensions"
hide = true
run = "npm update"

[tasks."update:agent-skills"]
description = "Update global agent skills"
run = [
  "rm -rf ~/.agents ~/.pi/agent/skills",
  "bunx --bun skills add zlliang/skills --full-depth -g -y -a amp",
  "bunx --bun skills add vercel-labs/agent-browser --skill agent-browser --full-depth -g -y -a amp",
  {{- if eq .machine "work" }}
  "bunx --bun skills add https://gitlab.com/{{ .work.gitlabNamespace }}/personal/zilong.liang/skills --full-depth -g -y -a amp",
  "bunx --bun skills add https://gitlab.com/gitlab-org/ai/skills --skill glab glab-glql --full-depth -g -y -a amp",
  "bunx --bun skills add https://github.com/gleanwork/glean-cli --skill glean-cli --full-depth -g -y -a amp",
  "bunx --bun skills add googleworkspace/cli --skill gws-shared gws-gmail gws-calendar gws-drive gws-docs gws-sheets gws-slides --full-depth -g -y -a amp",
  "bunx --bun skills add https://gitlab.com/{{ .work.gitlabNamespace }}/genai-eng/coding-agent-tools/-/tree/main/common --skill bpages --full-depth -g -y -a amp",
  {{- end }}
]

{{- if eq .machine "work" }}

[tasks."update:bk"]
description = "Update BK CLI and its plugins"
run = [
  "bk update",
  "mkdir -p ~/.config/fish/completions && bk completion fish > ~/.config/fish/completions/bk.fish",
]

[tasks.bkauth]
description = "Log in to Booking.com"
run = [
  { task = "bkauth:ssh" },
  { task = "bkauth:auth" },
  { task = "bkauth:glean-auth" },
]

[tasks."bkauth:ssh"]
description = "SSH to Booking.com"
interactive = true
run = "ssh -A ssh.booking.com"

[tasks."bkauth:auth"]
description = "Authenticate with BK CLI"
run = "bk auth:login --skip-okta-auth"

[tasks."bkauth:glean-auth"]
description = "Authenticate with Glean CLI"
run = "glean-auth-login"

{{- end }}
